PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hikvision_events?schema=public
NODE_ENV=development
JWT_SECRET=your-secure-jwt-secret
ADMIN_PASSWORD=your-admin-password
ALLOWED_HOSTS=localhost,127.0.0.1
ENFORCE_HTTPS=false
TRUST_PROXY=1
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RAW_PAYLOAD_RETENTION_DAYS=90
TIMEZONE=UTC
MAX_FUTURE_SKEW_SECONDS=300
MAX_PAST_SKEW_SECONDS=86400
CLOCK_SKEW_POLICY=normalize
